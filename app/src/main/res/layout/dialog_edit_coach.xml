<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/etCoachName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_dark"
            android:hint="Tên HLV"
            android:paddingStart="12dp"
            android:textColor="@color/text_white"
            android:layout_marginTop="8dp"/>

        <EditText
            android:id="@+id/etCoachAge"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_dark"
            android:hint="Tuổi"
            android:inputType="number"
            android:paddingStart="12dp"
            android:textColor="@color/text_white"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etCoachNationality"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_dark"
            android:hint="Quốc tịch"
            android:paddingStart="12dp"
            android:textColor="@color/text_white"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etCoachTeam"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_dark"
            android:hint="Đội bóng"
            android:paddingStart="12dp"
            android:textColor="@color/text_white"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etCoachExp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_dark"
            android:hint="Kinh nghiệm"
            android:paddingStart="12dp"
            android:textColor="@color/text_white"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etCoachAchievements"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_dark"
            android:hint="Thành tích"
            android:paddingStart="12dp"
            android:textColor="@color/text_white"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
</ScrollView>