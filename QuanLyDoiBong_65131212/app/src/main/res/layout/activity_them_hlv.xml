<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/white"
            app:title="KÝ HỢP ĐỒNG HLV"
            app:titleCentered="true"
            app:titleTextColor="@color/white"
            android:onClick="onBackPressed" />

        <com.google.android.material.card.MaterialCardView
            style="@style/NeonCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_them_hlv_avatar"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:civ_border_color="@color/neon_green"
                    app:civ_border_width="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_chon_anh_hlv"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="CHỌN ẢNH"
                    android:textColor="@color/neon_green"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconTint="@color/neon_green" />

                <ProgressBar
                    android:id="@+id/pb_upload_hlv"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:indeterminate="true"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/NeonCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Mã HLV"
                    app:boxStrokeColor="@color/neon_green"
                    app:hintTextColor="@color/neon_green">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_ma_hlv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Tên HLV"
                    app:boxStrokeColor="@color/neon_green"
                    app:hintTextColor="@color/neon_green">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_ten_hlv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Tuổi"
                        app:boxStrokeColor="@color/neon_green"
                        app:hintTextColor="@color/neon_green">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_tuoi_hlv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Quốc tịch"
                        app:boxStrokeColor="@color/neon_green"
                        app:hintTextColor="@color/neon_green">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_quoc_tich_hlv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Đội bóng dẫn dắt"
                    app:boxStrokeColor="@color/neon_green"
                    app:hintTextColor="@color/neon_green">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_doi_bong_hlv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Số năm kinh nghiệm"
                    app:boxStrokeColor="@color/neon_green"
                    app:hintTextColor="@color/neon_green">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_kinh_nghiem_hlv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Thành tích"
                    app:boxStrokeColor="@color/neon_green"
                    app:hintTextColor="@color/neon_green">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_thanh_tich_hlv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_hlv"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:text="LƯU THÔNG TIN"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            app:backgroundTint="@color/neon_green"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>