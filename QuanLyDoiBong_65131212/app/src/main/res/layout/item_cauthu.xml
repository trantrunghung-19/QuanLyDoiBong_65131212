<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/neon_green_alpha"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/photo_container"
            android:layout_width="60dp"
            android:layout_height="80dp"
            app:cardBackgroundColor="@color/pitch_green"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_cauthu_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_report_image"
                app:tint="@color/text_grey" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ovr_container"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="@color/pitch_green"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintStart_toEndOf="@+id/photo_container"
            android:layout_marginStart="-15dp"
            app:layout_constraintTop_toTopOf="@+id/photo_container"
            android:layout_marginTop="-5dp">

            <TextView
                android:id="@+id/tv_chi_so_value"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="90"
                android:textColor="@color/neon_green"
                android:textSize="16sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/player_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/action_layout"
            app:layout_constraintStart_toEndOf="@+id/ovr_container"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_ten_cau_thu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên cầu thủ"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_so_ao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#10"
                    android:textColor="@color/neon_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@android:color/white"
                    android:alpha="0.5" />

                <TextView
                    android:id="@+id/tv_vi_tri_chi_so"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiền đạo"
                    android:textColor="@color/text_grey"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_thong_so"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="G: 12 | A: 5"
                android:textColor="@color/neon_green"
                android:textSize="12sp"
                android:alpha="0.8"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/action_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_sua_cau_thu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/neon_green" />

            <ImageButton
                android:id="@+id/btn_xoa_cau_thu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/warning_red" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>