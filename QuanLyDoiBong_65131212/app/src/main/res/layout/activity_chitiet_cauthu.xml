<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_chi_tiet"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/white"
            app:title="CHI TIẾT CẦU THỦ"
            app:titleCentered="true"
            app:titleTextColor="@color/white" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- FIFA Style Player Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/player_card_main"
                android:layout_width="match_parent"
                android:layout_height="380dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="32dp"
                app:cardElevation="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="@color/neon_green"
                app:strokeWidth="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.4"
                        android:background="@color/pitch_green"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_det_chi_so"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="91"
                                android:textColor="@color/neon_green"
                                android:textSize="64sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_det_vi_tri"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ST"
                                    android:textColor="@color/white"
                                    android:textSize="24sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_det_so_ao"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="#9"
                                    android:textColor="@color/neon_green"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_det_player"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:layout_marginTop="0dp"
                            android:scaleType="fitCenter"
                            android:src="@android:drawable/ic_menu_report_image" />

                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_det_ten"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="ERLING HAALAND"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/player_card_main" />

            <TextView
                android:id="@+id/tv_det_quoc_tich"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Norway"
                android:textColor="@color/neon_green"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_det_ten" />

            <!-- Stats & Progress Section -->
            <com.google.android.material.card.MaterialCardView
                style="@style/NeonCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@+id/tv_det_quoc_tich">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="CHỈ SỐ NĂNG LỰC"
                        android:textColor="@color/neon_green"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TỔNG QUÁT (OVR)"
                        android:textColor="@color/white"
                        android:textSize="11sp" />

                    <ProgressBar
                        android:id="@+id/pb_det_ovr"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:max="100"
                        android:progressTint="@color/neon_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BÀN THẮNG"
                        android:textColor="@color/white"
                        android:textSize="11sp" />

                    <ProgressBar
                        android:id="@+id/pb_det_goals"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:max="100"
                        android:progressTint="@color/neon_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KIẾN TẠO"
                        android:textColor="@color/white"
                        android:textSize="11sp" />

                    <ProgressBar
                        android:id="@+id/pb_det_assists"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:max="100"
                        android:progressTint="@color/neon_green" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_det_tuoi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24 TUỔI"
                            android:textColor="@color/text_grey"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_det_ma"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID: CT01"
                            android:textColor="@color/pitch_green"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</ScrollView>